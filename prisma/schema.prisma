// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  image          String?
  phone          String?
  hashedPassword String? // bcrypt-hashed password; null = legacy passwordless account
  role           String          @default("user") // "user" | "editor" | "support" | "admin"
  createdAt      DateTime        @default(now())
  accounts       Account[]
  sessions       Session[]
  orders         Order[]         @relation("UserOrders")
  addresses      Address[]
  paymentMethods PaymentMethod[]
  logs           Log[]

  @@index([role])
}

// NextAuth tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String
  brand        String?
  description  String
  price        Float
  comparePrice Float?
  category     String
  image        String?
  images       Json       @default("[]")
  specs        Json?
  stock        Int        @default(0)
  featured     Boolean    @default(false)
  rating       Float      @default(0)
  reviewCount  Int        @default(0)
  isNew        Boolean    @default(false)
  tags         Json       @default("[]")
  createdAt    DateTime   @default(now())
  cartItems    CartItem[]

  @@index([category])
  @@index([featured])
  @@index([stock])
}

model Order {
  id                String         @id @default(cuid())
  total             Float
  status            String         @default("pending")
  date              DateTime       @default(now())
  trackingNumber    String?        @unique
  carrier           String?
  estimatedDelivery DateTime?
  shippingAddress   Json?
  paymentMethodId   String?
  paymentMethod     PaymentMethod? @relation("PaymentOrder", fields: [paymentMethodId], references: [id])
  items             CartItem[]
  userId            String?
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull, name: "UserOrders")
  cancelled         Boolean        @default(false)

  @@index([userId])
  @@index([status])
  @@index([date])
  @@index([paymentMethodId])
}

model Address {
  id      String  @id @default(cuid())
  user    User    @relation(fields: [userId], references: [id])
  userId  String
  label   String
  line1   String
  line2   String?
  city    String
  state   String?
  postal  String
  country String

  @@index([userId])
}

model CartItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model PaymentMethod {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  type           String   @default("card")
  brand          String
  stripeId       String?
  last4          String?
  expMonth       Int?
  expYear        Int?
  cardholderName String?
  accountEmail   String?
  createdAt      DateTime @default(now())

  orders Order[] @relation("PaymentOrder")

  @@index([userId])
}

/// newsletter / early-access subscribers
model Subscriber {
  id       String   @id @default(cuid())
  email    String   @unique
  joinedAt DateTime @default(now())
}

/// admin audit log — who changed what and when
model Log {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  adminEmail String
  action     String // "create" | "update" | "delete"
  entity     String // "product" | "order" | "user" | ...
  entityId   String?
  detail     String?
  admin      User     @relation(fields: [adminEmail], references: [email], onDelete: Cascade)

  @@index([timestamp])
  @@index([adminEmail])
  @@index([entity])
}
