{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:db": "docker compose up -d postgres redis",
    "dev": "sh ./scripts/dev.sh",
    "build": "next build",
    "start": "next start -p 3030",
    "lint": "eslint",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "seed:db": "ts-node prisma/seed.ts",
    "rust:build:wasm": "cd rust-agents/crates/compute && npx wasm-pack build --target web --out-dir ../../pkg --release",
    "rust:build:service": "cd rust-agents/crates/service && cargo build --release",
    "rust:run:service": "cd rust-agents/crates/service && cargo run",
    "agent:new": "ts-node scripts/newAgent.ts",
    "agent:sync": "ts-node scripts/syncAgents.ts",
    "agent:run": "ts-node agents/runner.ts",
    "dev:full": "sh ./scripts/dev.sh",
    "postinstall": "[ -d rust-agents/crates/compute ] && npm run rust:build:wasm || true",
    "dev:rust": "npm run rust:build:wasm && npm run dev",
    "start:all": "bash ./scripts/start-all.sh"
  },
  "dependencies": {
    "@clerk/nextjs": "6.37.5",
    "@langchain/core": "^0.3.12",
    "@langchain/groq": "^0.1.0",
    "@langchain/langgraph": "^0.2.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@paypal/react-paypal-js": "^9.0.0",
    "@prisma/adapter-better-sqlite3": "^7.4.1",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/dockerode": "^4.0.1",
    "@types/three": "^0.182.0",
    "autoprefixer": "10.4.24",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockerode": "^4.0.9",
    "framer-motion": "^12.34.1",
    "fuse.js": "^7.1.0",
    "langchain": "^0.3.12",
    "lucide-react": "^0.574.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "node-cron": "^4.2.1",
    "postcss": "8.5.6",
    "prisma": "^7.4.1",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "redis": "^4.7.0",
    "resend": "6.9.2",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@sentry/nextjs": "^10.40.0",
    "@types/change-case": "^0.0.30",
    "@types/node": "^20",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "change-case": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "next-test-api-route-handler": "^1.1.0",
    "supertest": "^6.3.3",
    "tailwindcss": "3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vercel": "^50.18.2",
    "vitest": "^0.34.1",
    "wasm-pack": "^0.12.1",
    "js-yaml": "^4.1.0"
  }
}
