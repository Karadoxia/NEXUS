{
  "name": "\ud83e\udd16 NEXUS - Full Site Audit Bot",
  "description": "Weekly comprehensive site audit with auto-fixes",
  "version": 1,
  "active": true,
  "nodes": [
    {
      "parameters": {
        "cronExpression": "0 3 * * 0"
      },
      "id": "cron_weekly",
      "name": "Every Sunday 3am UTC",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "completed"
            }
          ]
        }
      },
      "id": "audit_database",
      "name": "Audit Database",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "completed"
            }
          ]
        }
      },
      "id": "audit_security",
      "name": "Audit Security",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "completed"
            }
          ]
        }
      },
      "id": "audit_links",
      "name": "Check Broken Links",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "method": "POST",
        "authentication": "queryAuth",
        "sendQuery": true,
        "jsonBody": true,
        "body": "{\"contents\": [{\"role\": \"user\", \"content\": \"You are a site audit expert. Analyze the following audit results and generate a comprehensive report.\\n\\nDatabase Audit: {{ $json?.status || 'completed' }}\\nSecurity Audit: {{ $json?.status || 'completed' }}\\nLink Check: {{ $json?.status || 'completed' }}\\n\\nProvide: 1) Issues found 2) Severity levels 3) Recommended actions\"}]}"
      },
      "id": "gemini_audit_summary",
      "name": "Gemini: Generate Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "fromEmail": "audit@nexus.store",
        "toEmail": "{{ $env.ADMIN_EMAIL }}",
        "subject": "\ud83e\udd16 Weekly Site Audit Report",
        "html": "={{ $response?.body?.candidates?.[0]?.content?.parts?.[0]?.text || '<p>Audit completed successfully. Check detailed results in the workflow execution logs.</p>' }}"
      },
      "id": "send_audit_report",
      "name": "Send Report",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [
        1340,
        300
      ],
      "credentials": {
        "smtp": "email-resend-1"
      }
    },
    {
      "parameters": {
        "chatId": "{{ $env.TELEGRAM_CHAT_ID }}",
        "text": "\u2705 Weekly site audit completed\\nCheck email for full report"
      },
      "id": "notify_audit",
      "name": "Notify Completion",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [
        1560,
        300
      ],
      "credentials": {
        "telegram": "telegram-nexus-1"
      }
    }
  ],
  "connections": {
    "Every Sunday 3am UTC": {
      "main": [
        [
          {
            "node": "Audit Database",
            "type": "main",
            "index": 0
          },
          {
            "node": "Audit Security",
            "type": "main",
            "index": 0
          },
          {
            "node": "Check Broken Links",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Audit Database": {
      "main": [
        [
          {
            "node": "Gemini: Generate Report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Audit Security": {
      "main": [
        [
          {
            "node": "Gemini: Generate Report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Broken Links": {
      "main": [
        [
          {
            "node": "Gemini: Generate Report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Gemini: Generate Report": {
      "main": [
        [
          {
            "node": "Send Report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Report": {
      "main": [
        [
          {
            "node": "Notify Completion",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "errorWorkflow": "Global Error Notifier"
  },
  "tags": [
    "maintenance",
    "audit",
    "quality-assurance",
    "ai"
  ]
}