{
  "name": "\ud83d\udcbe NEXUS - Automated Backup + Offsite Upload",
  "description": "Daily automated backup with integrity verification",
  "version": 1,
  "active": true,
  "nodes": [
    {
      "parameters": {
        "cronExpression": "0 2 * * *"
      },
      "id": "cron_daily",
      "name": "Every Day 2am UTC",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "url": "http://nexus-rust-service:8080/backup/database",
        "method": "POST",
        "jsonBody": true,
        "body": "{\"format\": \"sql\", \"gzip\": true}"
      },
      "id": "trigger_db_backup",
      "name": "Trigger DB Backup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "url": "http://nexus-rust-service:8080/backup/files",
        "method": "POST",
        "jsonBody": true,
        "body": "{\"directories\": [\"public\", \"data\"], \"gzip\": true}"
      },
      "id": "trigger_files_backup",
      "name": "Trigger Files Backup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "url": "http://nexus-rust-service:8080/backup/upload",
        "method": "POST",
        "jsonBody": true,
        "body": "{\"destinations\": [\"s3\", \"backblaze\"], \"verify\": true}"
      },
      "id": "upload_offsite",
      "name": "Upload to Offsite",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $response.statusCode }}",
              "operation": "equals",
              "value2": "200"
            }
          ]
        }
      },
      "id": "check_success",
      "name": "IF Upload Successful",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "{{ $env.TELEGRAM_CHAT_ID }}",
        "text": "\u2705 Daily backup completed and verified\\nDB + Files uploaded to S3 & Backblaze"
      },
      "id": "notify_success",
      "name": "Notify Success",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [
        1340,
        200
      ],
      "credentials": {
        "telegram": {
          "id": "telegram-nexus-1"
        }
      }
    },
    {
      "parameters": {
        "chatId": "{{ $env.TELEGRAM_CHAT_ID }}",
        "text": "\u274c Backup failed! Check logs immediately."
      },
      "id": "notify_failure",
      "name": "Alert Failure",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [
        1340,
        400
      ],
      "credentials": {
        "telegram": {
          "id": "telegram-nexus-1"
        }
      }
    }
  ],
  "connections": {
    "Every Day 2am UTC": {
      "main": [
        [
          {
            "node": "Trigger DB Backup",
            "type": "main",
            "index": 0
          },
          {
            "node": "Trigger Files Backup",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger DB Backup": {
      "main": [
        [
          {
            "node": "Upload to Offsite",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger Files Backup": {
      "main": [
        [
          {
            "node": "Upload to Offsite",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Upload to Offsite": {
      "main": [
        [
          {
            "node": "IF Upload Successful",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF Upload Successful": {
      "main": [
        [
          {
            "node": "Notify Success",
            "type": "main",
            "index": 0
          },
          {
            "node": "Alert Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "errorWorkflow": "Global Error Notifier"
  },
  "tags": [
    "backup",
    "disaster-recovery",
    "data-safety"
  ]
}