      "id": 1,
      "title": "NEXUS-V2 SLO Dashboard - Production Reliability Tracking",
      "type": "text",
      "options": {
        "text": "# Service Level Objectives (SLOs) & Error Budget Tracking\n\n**Target SLOs:**\n- **Availability:** 99.9% uptime (allow ~43 min downtime/month)\n- **Latency:** P95 < 500ms (response time)\n- **Error Rate:** < 1% of requests returning 5xx errors\n\n**Error Budget:** If we consume this, we lose compliance for the month"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "HEALTHY",
                  "color": "green"
                },
                "0": {
                  "text": "BREACHED",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 2
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "fields": "",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "(1 - (increase(http_requests_total{status=~\"5..\"}[30m]) / clamp_min(increase(http_requests_total[30m]), 1))) * ((1 - 0.999) / (1 - avg_over_time((1 - (increase(http_requests_total{status=~\"5..\"}[1h]) / clamp_min(increase(http_requests_total[1h]), 1)))[30m:1m])))",
          "legendFormat": "Error Budget Status",
          "refId": "A"
        }
      ],
      "title": "Error Budget Status (5xx < 1%)",
      "type": "stat"
    },
